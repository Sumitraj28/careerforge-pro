# Server
NODE_ENV=development
PORT=5001

# Database (required in production)
MONGODB_URI=mongodb://localhost:27017/careerforge
# Optional: force in-memory MongoDB (development only; never in production).
# USE_MONGO_MEMORY_SERVER=true
# Optional: if MONGODB_URI is wrong in dev, we auto-switch to memory unless:
# USE_MONGO_MEMORY_SERVER=false
# DISABLE_MONGO_DEV_MEMORY_FALLBACK=true

# Auth
JWT_SECRET=your_jwt_secret_at_least_32_chars
JWT_REFRESH_SECRET=your_refresh_secret

# AI
GEMINI_API_KEY=your_gemini_api_key

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# URLs
FRONTEND_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Deployment
# Only needed for certain cloud platforms (e.g. Railway/Render)
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome-stable

