# ============================================================
#  CareerForge Pro — Backend Environment Variables
#  Copy this file to .env and fill in your real values.
# ============================================================

# ── Server ──────────────────────────────────────────────────
NODE_ENV=development
PORT=5001

# ── MongoDB Atlas ───────────────────────────────────────────
# REQUIRED — Your MongoDB Atlas connection string.
# Get it from: https://cloud.mongodb.com → Database → Connect → Drivers
MONGODB_URI=mongodb+srv://<db_user>:<db_password>@<cluster>.mongodb.net/careerforge?appName=Cluster0

# ── Authentication ──────────────────────────────────────────
# REQUIRED — Secret used to sign JWT tokens (min 32 characters).
JWT_SECRET=your_jwt_secret_at_least_32_chars_long_here

# ── Google Gemini AI ────────────────────────────────────────
# REQUIRED — Powers ATS scoring, resume rewriting, cover letters.
# Get it from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Stripe Payments ─────────────────────────────────────────
# REQUIRED — Your Stripe SECRET key (starts with sk_test_ or sk_live_).
# Get it from: https://dashboard.stripe.com/apikeys
# ⚠️  Must be a "Secret key" (sk_test_...), NOT a "Restricted key" (rk_test_...).
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# OPTIONAL — Stripe webhook secret for verifying webhook signatures.
# Get it from: https://dashboard.stripe.com/webhooks → select endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ── Frontend URL ────────────────────────────────────────────
# REQUIRED in production — Used for CORS and Stripe redirect URLs.
# For local dev: http://localhost:3000
# For production: https://your-app.vercel.app
FRONTEND_URL=http://localhost:3000

# ── Google OAuth ────────────────────────────────────────────
# REQUIRED for Google Sign-In.
# Get it from: https://console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here

# ── Optional: Anthropic Claude (backup AI) ──────────────────
# OPTIONAL — Only needed if you switch to Claude as the AI provider.
# ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here

# ── Optional: Puppeteer (PDF generation on cloud) ──────────
# Only needed on Render/Railway where Chrome must be installed separately.
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome-stable
