# ============================================================
#  CareerForge Pro — Frontend Environment Variables
#  Copy this file to .env and fill in your real values.
# ============================================================

# ── Backend API URL ─────────────────────────────────────────
# Leave EMPTY during local dev to use the Vite proxy (see vite.config.js).
# In production (Vercel): Set to your Render backend URL.
# Example: https://careerforge-backend.onrender.com
VITE_BACKEND_URL=

# ── Google OAuth Client ID ──────────────────────────────────
# REQUIRED for Google Sign-In button.
# Must be the SAME Client ID used in the backend.
# Get it from: https://console.cloud.google.com → APIs & Services → Credentials
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id_here

# ── Stripe Publishable Key ─────────────────────────────────
# REQUIRED for Stripe payment flow.
# Get it from: https://dashboard.stripe.com/apikeys → Publishable key
# Starts with pk_test_ (test mode) or pk_live_ (live mode).
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
