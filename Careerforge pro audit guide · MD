### 7.4 Gemini API Response Caching
For identical JD → keyword extraction requests, cache results:
```js
// In geminiService.js
const cache = new Map();
async function extractKeywords(jobDescription) {
  const key = Buffer.from(jobDescription).toString('base64').slice(0, 64);
  if (cache.has(key)) return cache.get(key);
  const result = await getModel().generateContent(prompt);
  cache.set(key, result);
  setTimeout(() => cache.delete(key), 30 * 60 * 1000); // 30-min TTL
  return result;
}
```

